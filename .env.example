# Copy this file to .env.local and fill in the real values.
# .env.local is git-ignored; values here ship to Vercel via Project Settings.

# WhatsApp click-to-chat number — international format, no leading +, no spaces.
# Example: Malaysian +60 16-917 7882 becomes 60169177882.
NEXT_PUBLIC_WHATSAPP_NUMBER=60123456789

# Analytics — either one is optional; leave a line out to disable that script.

# Google Analytics 4 — get this from analytics.google.com (Admin → Data Streams)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel — from Meta Events Manager → Data Sources
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# Base URL used in OG meta, JSON-LD, sitemap. Set this on Vercel once a real
# domain is wired; defaults to https://parkgreen.vercel.app locally.
NEXT_PUBLIC_SITE_URL=https://parkgreen.vercel.app
